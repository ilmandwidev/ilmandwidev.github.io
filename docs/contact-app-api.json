{
    "openapi": "3.0.3",
    
    "info": {
        "title": "Contact App API",
        "description": "Simple Contact App API",
        "version": "1.0.0"
    },
    "servers": [
        {
            
            "url": "https://contact-app-restful-api.adaptable.app"
        }
