                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                
                                                "username": {
                                                    "type": "string"
                                                },
                                                "name": {
                                                    "type": "string"
